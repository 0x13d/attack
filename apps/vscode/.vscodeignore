# The extension is bundled into out/extension.js (esbuild), so the .vsix ships only that + the static
# contribution assets (schemas/, snippets/) and the marketplace icon. Everything below is build input,
# and the README media are served from raw.githubusercontent, not bundled.
src/**
node_modules/**
.vscode/**
tsconfig.json
esbuild.mjs
package-lock.json
.gitignore
**/*.ts
**/*.map
media/**
assets/**
!assets/icon.png
