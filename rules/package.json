{
  "name": "0x13d-attack-rules-community",
  "version": "0.1.0",
  "description": "The 0x13d::att&ck community rule set — 16 MITRE ATT&CK browser-EDR detection rules (rules + pure detection logic + bounded responses) for Manifest V3 extensions. Zero host permissions, no network egress.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/0x13d/attack.git",
    "directory": "rules"
  },
  "keywords": [
    "mitre",
    "attack",
    "browser-edr",
    "detection-rules",
    "security",
    "chrome-extension",
    "manifest-v3"
  ],
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./detection/*": {
      "types": "./dist/cjs/detection/*.d.ts",
      "import": "./dist/esm/detection/*.js",
      "require": "./dist/cjs/detection/*.js"
    },
    "./rules/*": {
      "types": "./dist/cjs/rules/*.d.ts",
      "import": "./dist/esm/rules/*.js",
      "require": "./dist/cjs/rules/*.js"
    },
    "./compile": {
      "types": "./dist/cjs/compile.d.ts",
      "import": "./dist/esm/compile.js",
      "require": "./dist/cjs/compile.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/cjs/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && tsc -p tsconfig.esm.json && node scripts/fix-esm-ext.mjs && node -e \"require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'})+'\\n')\"",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "scenarios": "tsx scenarios/harness.ts"
  },
  "dependencies": {
    "@attack/rule-schema": "*"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  }
}
